{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ImageUpload": {
    "MaxFileSize": 5242880,
    "AllowedExtensions": [
      ".jpg",
      ".jpeg",
      ".png",
      ".webp"
    ],
    "AllowedContentTypes": [
      "image/jpeg",
      "image/png",
      "image/webp"
    ]
}
}
